{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../ts-config/base.json",
  "compilerOptions": {
    "noUnusedLocals": false,
    "types": ["node"],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.vue"],
  "exclude": ["node_modules", "dist"]
}
