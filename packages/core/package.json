{
  "name": "@xv-shared/core",
  "type": "module",
  "version": "0.3.0",
  "description": "Vue 3 runtime utilities, hooks, directives, HTTP client, and components for XtraVisions frontend projects",
  "author": "XtraVisions",
  "license": "MIT",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./utils": {
      "types": "./dist/src/utils/index.d.ts",
      "import": "./dist/utils/index.mjs"
    },
    "./hooks": {
      "types": "./dist/src/hooks/index.d.ts",
      "import": "./dist/hooks/index.mjs"
    },
    "./directives": {
      "types": "./dist/src/directives/index.d.ts",
      "import": "./dist/directives/index.mjs"
    },
    "./request": {
      "types": "./dist/src/request/index.d.ts",
      "import": "./dist/request/index.mjs"
    },
    "./router": {
      "types": "./dist/src/router/index.d.ts",
      "import": "./dist/router/index.mjs"
    },
    "./components/*": {
      "types": "./dist/src/components/*/index.d.ts",
      "import": "./dist/components/*/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "clean": "rimraf dist"
  },
  "peerDependencies": {
    "vue": "^3.4.0",
    "vue-router": "^4.0.0 || ^5.0.0",
    "naive-ui": "^2.38.0"
  },
  "peerDependenciesMeta": {
    "vue-router": {
      "optional": true
    },
    "naive-ui": {
      "optional": true
    }
  },
  "dependencies": {
    "@vueuse/core": "catalog:",
    "lodash-es": "catalog:",
    "vue-draggable-plus": "catalog:"
  },
  "devDependencies": {
    "@types/lodash-es": "catalog:",
    "@types/node": "catalog:",
    "@vitejs/plugin-vue": "catalog:",
    "naive-ui": "catalog:",
    "sass-embedded": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-dts": "catalog:",
    "vue": "catalog:",
    "vue-router": "catalog:"
  }
}
